generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id            Int           @id @default(autoincrement())
  name          String
  type          String
  startDate     DateTime?
  endDate       DateTime?
  startTime     String?
  endTime       String?
  location      String
  image         String
  galleryImages Json?
  galleryVideos Json?
  status        String
  agenda        Json?
  book          Json?
  contactUs     Json?
  info          Json?
  mediaKit      Json?
  overview      Json?
  speakers      Json?
  sponsors      Json?
  venue         Json?
  guestPrice    Int           @default(0)
  memberPrice   Int           @default(0)
  EventBooking  EventBooking[]
  tickets       EventTicket[]
}

model EventTicket {
  id          String @id @default(cuid())
  eventId     Int
  name        String
  price       Int
  description String
  quantity    Int
  sold        Int    @default(0)
  isFree      Boolean @default(false)
  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bookings    EventBooking[]
}

model EventBooking {
  id           String       @id @default(cuid())
  eventId      Int
  ticketId     String?
  attendeeName String
  email        String
  phone        String?
  quantity     Int          @default(1)
  amount       Int          @default(0)
  paymentId    String?
  status       String       @default("PENDING")
  createdAt    DateTime     @default(now())
  event        Event        @relation(fields: [eventId], references: [id])
  ticket       EventTicket? @relation(fields: [ticketId], references: [id])
}
