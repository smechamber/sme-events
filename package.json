{
  "name": "events-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "description": "Enterprise event management platform with public website, admin dashboard, API, and shared packages.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:push": "prisma db push --schema packages/db/prisma/schema.prisma",
    "db:pull": "prisma db pull --schema packages/db/prisma/schema.prisma",
    "db:studio": "prisma studio --schema packages/db/prisma/schema.prisma",
    "db:validate": "prisma validate --schema packages/db/prisma/schema.prisma",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@sme/media-sdk": "github:smechamber/sme-media-sdk"
  }
}
